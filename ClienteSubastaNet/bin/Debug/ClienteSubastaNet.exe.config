<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
    <system.serviceModel>
        <bindings>
            <basicHttpBinding>
                <binding name="BasicHttpBinding_IInicioSesionServicio" />
                <binding name="BasicHttpBinding_IInicioSesionServicio1" />
            </basicHttpBinding>
            <wsDualHttpBinding>
                <binding name="WSDualHttpBinding_ISubastaServicio" />
            </wsDualHttpBinding>
        </bindings>
        <client>
            <endpoint address="http://localhost:52610/SubastaServicio.svc"
                binding="wsDualHttpBinding" bindingConfiguration="WSDualHttpBinding_ISubastaServicio"
                contract="SubastaServicioRemoto.ISubastaServicio" name="WSDualHttpBinding_ISubastaServicio">
                <identity>
                    <userPrincipalName value="TRESDESELAP\super" />
                </identity>
            </endpoint>
            <endpoint address="http://localhost:52610/InicioSesionServicio.svc"
                binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IInicioSesionServicio"
                contract="InicioSesionServicioCliente.IInicioSesionServicio"
                name="BasicHttpBinding_IInicioSesionServicio" />
            <endpoint address="http://localhost:52610/InicioSesionServicio.svc"
                binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IInicioSesionServicio1"
                contract="InicioSesionServicio.IInicioSesionServicio" name="BasicHttpBinding_IInicioSesionServicio1" />
        </client>
    </system.serviceModel>
</configuration>