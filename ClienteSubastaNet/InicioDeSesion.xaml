<Window x:Class="ClienteSubastaNet.InicioDeSesion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClienteSubastaNet"
        mc:Ignorable="d"
        Title="Inicio de sesion" Height="280" Width="400" WindowStartupLocation="CenterScreen">
    <Grid Margin="20" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="Blue" CornerRadius="5" Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Sala de subastas" FontSize="12" Foreground="Beige" HorizontalAlignment="Center" FontWeight="Bold"/>
                <TextBlock Text="Identificate para continuar" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Nombre de usuario" FontSize="12" Foreground="Gray" Margin="0,0,0,5"/>
            <TextBox x:Name="txtNombreUsuario" FontSize="16" Padding="6" Height="38" VerticalContentAlignment="Center" BorderBrush="Black"/>
        </StackPanel>

        <Button x:Name="btnEntrar" Grid.Row="2" Content="Entrar a la sala" Height="38" Background="DarkGreen" Foreground="White" FontSize="14" FontWeight="Bold" Click="btnEntrar_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>